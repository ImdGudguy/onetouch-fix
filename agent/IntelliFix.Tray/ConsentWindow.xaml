<Window x:Class="IntelliFix.Tray.ConsentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IntelliFix Consent"
        Width="480" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" Topmost="True" ShowInTaskbar="False">

    <Window.Resources>
        <LinearGradientBrush x:Key="Accent" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#00E5FF" Offset="0"/>
            <GradientStop Color="#A855F7" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Background" Value="#1AFFFFFF"/>
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="12" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#26FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#00E5FF" Offset="0"/>
                                    <GradientStop Color="#A855F7" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#00E5FF" BlurRadius="22" ShadowDepth="0" Opacity="0.6"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.92"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RenderTransform>
            <ScaleTransform x:Name="rootScale" ScaleX="0.9" ScaleY="0.9" CenterX="216" CenterY="200"/>
        </Grid.RenderTransform>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="rootScale" Storyboard.TargetProperty="ScaleX" From="0.9" To="1" Duration="0:0:0.25"/>
                        <DoubleAnimation Storyboard.TargetName="rootScale" Storyboard.TargetProperty="ScaleY" From="0.9" To="1" Duration="0:0:0.25"/>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>

        <!-- Glow border -->
        <Border CornerRadius="24" BorderThickness="1.5">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#6600E5FF" Offset="0"/>
                    <GradientStop Color="#33A855F7" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#F212121A" Offset="0"/>
                    <GradientStop Color="#F50A0A12" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="0" Opacity="0.7"/>
            </Border.Effect>

            <StackPanel Margin="28">
                <!-- Icon -->
                <Border Width="68" Height="68" CornerRadius="18" HorizontalAlignment="Center"
                        Background="#1A00E5FF" BorderBrush="#3300E5FF" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="#00E5FF" BlurRadius="24" ShadowDepth="0" Opacity="0.7"/>
                    </Border.Effect>
                    <TextBlock Text="&#x26A1;" FontSize="34" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#00E5FF"/>
                </Border>

                <TextBlock Text="Confirm Remediation" FontSize="22" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" Margin="0,16,0,4"/>
                <TextBlock x:Name="LabelText" FontSize="15" FontWeight="SemiBold" Foreground="#00E5FF"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock x:Name="DescText" FontSize="12.5" Foreground="#99A3B5" TextWrapping="Wrap"
                           TextAlignment="Center" Margin="6,0,6,18"/>

                <!-- Stats -->
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock x:Name="ConfText" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="AI Confidence" FontSize="10" Foreground="#66738A" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <Border Grid.Column="1" Width="1" Background="#22FFFFFF" Margin="8,4"/>
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock x:Name="TimeText" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="Est. Time" FontSize="10" Foreground="#66738A" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <Border Grid.Column="3" Width="1" Background="#22FFFFFF" Margin="8,4"/>
                    <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                        <TextBlock x:Name="RateText" FontSize="20" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Center"/>
                        <TextBlock Text="Success Rate" FontSize="10" Foreground="#66738A" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Warning -->
                <Border CornerRadius="10" Background="#1AFACC15" BorderBrush="#33FACC15" BorderThickness="1" Padding="10,8" Margin="0,0,0,18">
                    <TextBlock Text="&#x26A0; This action runs on your device. You can decline at any time."
                               FontSize="11" Foreground="#FACC15" TextWrapping="Wrap" TextAlignment="Center"/>
                </Border>

                <!-- Buttons -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource GhostBtn}" Content="No, Cancel" Click="OnDeny"/>
                    <Button Grid.Column="2" Style="{StaticResource PrimaryBtn}" Content="Yes, Execute Fix" Click="OnApprove"/>
                </Grid>

                <TextBlock x:Name="CountdownText" FontSize="10" Foreground="#445" HorizontalAlignment="Center" Margin="0,12,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
