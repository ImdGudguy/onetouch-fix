# =========================================================================
# IntelliFix / OneTouch-Fix — environment configuration
# Copy to ".env.local" (dev) or set as real env vars in your host.
# NOTHING in this product is hardcoded — all secrets come from here.
# =========================================================================

# --- Claude (Anthropic) API: powers the in-app assistant -----------------
# Get a key at https://console.anthropic.com/. Without it the assistant
# falls back to a local, telemetry-grounded responder (reduced capability).
ANTHROPIC_API_KEY=

# Model used by the assistant (defaults to the most capable current Claude model).
ANTHROPIC_MODEL=claude-opus-4-8

# --- Agent <-> backend shared secret -------------------------------------
# When set, every /api/agent/* call MUST present this token (header
# x-intellifix-token). Leave empty ONLY for a trusted localhost demo.
# Generate one:  openssl rand -hex 32
INTELLIFIX_AGENT_TOKEN=

# --- Public base URL (optional) ------------------------------------------
# Used in docs / agent install hints. The web app itself calls /api on the
# same origin, so this is informational unless you split web and API.
NEXT_PUBLIC_API_URL=/api
